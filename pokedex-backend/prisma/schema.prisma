generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// PHASE 1: CORE POKEDEX MODELS
// ==========================================

model Pokemon {
  id             Int       @id @default(autoincrement())
  pokedexNumber  Int       @unique
  generation     Int       @default(1)
  name           String    @unique
  height         Int?
  weight         Int?
  baseExperience Int?
  imageUrl       String?   // Official artwork
  shinyImageUrl  String?   // Shiny official artwork
  category       String?


  // Base Stats
  hp             Int
  attack         Int
  defense        Int
  specialAttack  Int
  specialDefense Int
  speed          Int

  // Relations
  types          Type[]
  abilities      Ability[]
  gameVersions   GameVersion[]
  varieties      PokemonVariety[]

  // Evolutions
  evolvesTo      Evolution[] @relation("EvolvesFrom")
  evolvesFrom    Evolution[] @relation("EvolvesTo")

  // Phase 2 Relations
  userPokemons   UserPokemon[]

  // Phase 3 Relations
  teamSlots      TeamSlot[]
  moves          PokemonMove[]
}

model Type {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  pokemons Pokemon[]
}

model Ability {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  pokemons Pokemon[]
}

model GameVersion {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  pokemons Pokemon[]
}

model Evolution {
  id             Int     @id @default(autoincrement())
  fromPokemonId  Int
  toPokemonId    Int
  
  fromPokemon    Pokemon @relation("EvolvesFrom", fields: [fromPokemonId], references: [pokedexNumber])
  toPokemon      Pokemon @relation("EvolvesTo", fields: [toPokemonId], references: [pokedexNumber])

  @@unique([fromPokemonId, toPokemonId])
}

// ==========================================
// PHASE 2 & 3: USER DATA & TEAM BUILDER
// ==========================================

model User {
  id           Int       @id @default(autoincrement())
  username     String    @unique
  email        String    @unique
  passwordHash String

  userPokemons UserPokemon[]
  team         Team?
}

model UserPokemon {
  userId    Int
  pokemonId Int
  user      User    @relation(fields: [userId], references: [id])
  pokemon   Pokemon @relation(fields: [pokemonId], references: [id])

  @@id([userId, pokemonId])
}

model Team {
  id        Int        @id @default(autoincrement())
  userId    Int        @unique // 1 team per user
  user      User       @relation(fields: [userId], references: [id])
  slots     TeamSlot[]
}

model TeamSlot {
  teamId    Int
  pokemonId Int
  slotOrder Int      // Position 1 to 6
  
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  pokemon   Pokemon  @relation(fields: [pokemonId], references: [pokedexNumber])

  @@id([teamId, slotOrder])
}

// ==========================================
// PHASE 4: MOVESET DETAILS
// ==========================================

model Move {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  power       Int?
  accuracy    Int?
  type        String
  damageClass String
  
  pokemonMoves PokemonMove[]
}

model PokemonMove {
  pokemonId      Int
  moveId         Int
  learnMethod    String
  levelLearnedAt Int

  pokemon Pokemon @relation(fields: [pokemonId], references: [pokedexNumber], onDelete: Cascade)
  move    Move    @relation(fields: [moveId], references: [id], onDelete: Cascade)

  @@id([pokemonId, moveId, learnMethod])
}

model PokemonVariety {
  id             Int      @id
  pokemonId      Int
  name           String   @unique
  imageUrl       String?
  shinyImageUrl  String?
  isMega         Boolean  @default(false)
  isAlternative  Boolean  @default(false)
  types          String[]

  pokemon        Pokemon  @relation(fields: [pokemonId], references: [pokedexNumber], onDelete: Cascade)
}
